rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.username is string && data.username.size() >= 3 && data.username.size() <= 30
          && data.fullName is string && data.fullName.size() <= 100;
      }

      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'bio', 'website', 'avatar', 'postsCount', 'followersCount', 'followingCount']);
    }

    // Post Rules
    match /posts/{postId} {
      function isValidPost(data) {
        return data.userId == request.auth.uid
          && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1048))
          && (data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 1048))
          && (data.caption == null || (data.caption is string && data.caption.size() <= 2200))
          && data.type in ['image', 'video', 'reel'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(request.resource.data);
      allow update: if isSignedIn() && (
        // Liking (only modify likesCount)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        || (isOwner(resource.data.userId) && isValidPost(request.resource.data))
      );
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Story Rules
    match /stories/{storyId} {
      function isValidStory(data) {
        return data.userId == request.auth.uid
          && data.mediaUrl is string && data.mediaUrl.size() <= 1048
          && data.type in ['image', 'video'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStory(request.resource.data);
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        // Allow view count increments
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /views/{viewId} {
        allow read: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/stories/$(storyId)).data.userId) ||
          isOwner(viewId) // user can see their own view record
        );
        allow create: if isSignedIn() && request.auth.uid == viewId;
      }
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if isSignedIn() 
          && request.resource.data.senderId == request.auth.uid 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }
  }
}
